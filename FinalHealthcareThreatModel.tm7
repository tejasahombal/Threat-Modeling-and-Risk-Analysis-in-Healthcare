alue></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Repudiation threats involve an adversary denying that something happened.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Patient Mobile Application claims that it did not receive data from a process on the other side of the trust boundary. Consider using logging or auditing to record the source, time, and summary of the received data.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b6f64c45-d8f5-487d-8e88-fc41779fc4e8</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>af9ff8aa-8bd9-42fd-81d8-53c782d0b808</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R7</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D4b6f64c45-d8f5-487d-8e88-fc41779fc4e83a4bc32c-4456-4ec4-9bd1-77fa15cd089baf9ff8aa-8bd9-42fd-81d8-53c782d0b808</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>3a4bc32c-4456-4ec4-9bd1-77fa15cd089b</b:FlowGuid><b:Id>155</b:Id><b:InteractionKey>b6f64c45-d8f5-487d-8e88-fc41779fc4e8:3a4bc32c-4456-4ec4-9bd1-77fa15cd089b:af9ff8aa-8bd9-42fd-81d8-53c782d0b808</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Flow HTTPS Is Potentially Interrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent interrupts data flowing across a trust boundary in either direction.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b6f64c45-d8f5-487d-8e88-fc41779fc4e8</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>af9ff8aa-8bd9-42fd-81d8-53c782d0b808</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D4</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S8b4536c64-a9e7-4b07-ba96-70540e3c690cf40e86fc-1a0c-404c-baae-d11362db7a5330b193b0-89c1-4527-8d18-76db8a6d7ef0</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>f40e86fc-1a0c-404c-baae-d11362db7a53</b:FlowGuid><b:Id>156</b:Id><b:InteractionKey>b4536c64-a9e7-4b07-ba96-70540e3c690c:f40e86fc-1a0c-404c-baae-d11362db7a53:30b193b0-89c1-4527-8d18-76db8a6d7ef0</b:InteractionKey><b:In