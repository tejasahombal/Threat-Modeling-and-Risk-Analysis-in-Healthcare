d><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D337c76ac3-20ae-49bc-a167-1097b82daf9c8ae7d8e8-b120-4ce0-8035-88d24e1627b521100a18-2c24-4552-84fa-11e21abb76af</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>8ae7d8e8-b120-4ce0-8035-88d24e1627b5</b:FlowGuid><b:Id>184</b:Id><b:InteractionKey>37c76ac3-20ae-49bc-a167-1097b82daf9c:8ae7d8e8-b120-4ce0-8035-88d24e1627b5:21100a18-2c24-4552-84fa-11e21abb76af</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Process Crash or Stop for Medical Device Gateway</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Medical Device Gateway crashes, halts, stops or runs slowly; in all cases violating an availability metric.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>37c76ac3-20ae-49bc-a167-1097b82daf9c</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>21100a18-2c24-4552-84fa-11e21abb76af</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D3</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R637c76ac3-20ae-49bc-a167-1097b82daf9c8ae7d8e8-b120-4ce0-8035-88d24e1627b521100a18-2c24-4552-84fa-11e21abb76af</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>8ae7d8e8-b120-4ce0-8035-88d24e1627b5</b:FlowGuid><b:Id>183</b:Id><b:InteractionKey>37c76ac3-20ae-49bc-a167-1097b82daf9c:8ae7d8e8-b120-4ce0-8035-88d24e1627b5:21100a18-2c24-4552-84fa-11e21abb76af</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Data Repudiation by Medical Device Gateway</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Repudiation threats involve an adversary denying that something happened.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Medical Device Gateway claims that it did not receive data from a source outside the trust boundary. Consider using logging or auditing to record the source, time, and summary of the received data.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>37c76ac3-20ae-49bc-a167-1097b82daf9c</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>21100a18-2c24-4552-84fa-11e21abb76af</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T237c76ac3-20ae-49bc-a167-1097b82daf9c8ae7d8e8-b120-4ce0-8035-88d24e1627b521100a18-2c24-4552-84fa-11e21abb76af</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>8ae7d8e8-b120-4ce0-8035-88d24e1627b5</b:FlowGuid><b:Id>182</b:Id><b:InteractionKey>37c76ac3-20ae-49bc-a167-1097b82daf9c:8ae7d8e8-b120-4ce0-8035-88d24e1627b5:21100a18-2c24-4552-84fa-11e21abb76af</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Device Monitoring Service Process Memory Tampered</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>If Device Monitoring Service is given access to memory, such as shared memory or pointers, or is given the ability to control what Medical Device Gateway executes (for example, passing back a function pointer.), then Device Monitoring Service can tamper with Medical Device Gateway. Consider if the function could work with less access to memory, such as passing data rather than pointers. Copy in data provided, and then validate it.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>37c76ac3-20ae-49bc-a167-1097b82daf9c</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>21100a18-2c24-4552-84fa-11e21abb76af</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S137c76ac3-20ae-49bc-a167-1097b82daf9c8ae7d8e8-b120-4ce0-8035-88d24e1627b521100a18-2c24-4552-84fa-11e21abb76af</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>8ae7d8e8-b120-4ce0-8035-88d24e1627b5</b:FlowGuid><b:Id>181</b:Id><b:InteractionKey>37c76ac3-20ae-49bc-a167-1097b82daf9c:8ae7d8e8-b120-4ce0-8035-88d24e1627b5:21100a18-2c24-4552-84fa-11e21abb76af</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing the Device Monitoring Service Process</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Device Monitoring Service may be spoofed by an attacker and this may lead to unauthorized access to Medical Device Gateway. Consider using a standard authentication mechanism to identify the source process.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>37c76ac3-20ae-49bc-a167-1097b82daf9c</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>21100a18-2c24-4552-84fa-11e21abb76af</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S182ceafe9-ea4b-41f9-9200-86b17b49ffd823b19bb4-5a8e-4811-bd5d-1cf5b4f622acebdc6f14-0508-4217-80bb-a153c118b613</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac</b:FlowGuid><b:Id>137</b:Id><b:InteractionKey>82ceafe9-ea4b-41f9-9200-86b17b49ffd8:23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac:ebdc6f14-0508-4217-80bb-a153c118b613</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing the EHR Management System Process</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>EHR Management System may be spoofed by an attacker and this may lead to unauthorized access to Medical Imaging Storage (PACS). Consider using a standard authentication mechanism to identify the source process.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>82ceafe9-ea4b-41f9-9200-86b17b49ffd8</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>ebdc6f14-0508-4217-80bb-a153c118b613</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S7.182ceafe9-ea4b-41f9-9200-86b17b49ffd823b19bb4-5a8e-4811-bd5d-1cf5b4f622acebdc6f14-0508-4217-80bb-a153c118b613</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac</b:FlowGuid><b:Id>138</b:Id><b:InteractionKey>82ceafe9-ea4b-41f9-9200-86b17b49ffd8:23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac:ebdc6f14-0508-4217-80bb-a153c118b613</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing of Destination Data Store Medical Imaging Storage (PACS)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Medical Imaging Storage (PACS) may be spoofed by an attacker and this may lead to data being written to the attacker's target instead of Medical Imaging Storage (PACS). Consider using a standard authentication mechanism to identify the destination data store.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>82ceafe9-ea4b-41f9-9200-86b17b49ffd8</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>ebdc6f14-0508-4217-80bb-a153c118b613</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S7.1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T1882ceafe9-ea4b-41f9-9200-86b17b49ffd823b19bb4-5a8e-4811-bd5d-1cf5b4f622acebdc6f14-0508-4217-80bb-a153c118b613</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac</b:FlowGuid><b:Id>139</b:Id><b:InteractionKey>82ceafe9-ea4b-41f9-9200-86b17b49ffd8:23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac:ebdc6f14-0508-4217-80bb-a153c118b613</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>The Medical Imaging Storage (PACS) Data Store Could Be Corrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Data flowing across Binary may be tampered with by an attacker. This may lead to corruption of Medical Imaging Storage (PACS). Ensure the integrity of the data flow to the data store.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>82ceafe9-ea4b-41f9-9200-86b17b49ffd8</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>ebdc6f14-0508-4217-80bb-a153c118b613</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T18</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R882ceafe9-ea4b-41f9-9200-86b17b49ffd823b19bb4-5a8e-4811-bd5d-1cf5b4f622acebdc6f14-0508-4217-80bb-a153c118b613</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac</b:FlowGuid><b:Id>140</b:Id><b:InteractionKey>82ceafe9-ea4b-41f9-9200-86b17b49ffd8:23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac:ebdc6f14-0508-4217-80bb-a153c118b613</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Store Denies Medical Imaging Storage (PACS) Potentially Writing Data</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Repudiation threats involve an adversary denying that something happened.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Medical Imaging Storage (PACS) claims that it did not write data received from an entity on the other side of the trust boundary. Consider using logging or auditing to record the source, time, and summary of the received data.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>82ceafe9-ea4b-41f9-9200-86b17b49ffd8</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>ebdc6f14-0508-4217-80bb-a153c118b613</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R8</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>I682ceafe9-ea4b-41f9-9200-86b17b49ffd823b19bb4-5a8e-4811-bd5d-1cf5b4f622acebdc6f14-0508-4217-80bb-a153c118b613</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac</b:FlowGuid><b:Id>141</b:Id><b:InteractionKey>82ceafe9-ea4b-41f9-9200-86b17b49ffd8:23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac:ebdc6f14-0508-4217-80bb-a153c118b613</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Flow Sniffing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Information Disclosure</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Information disclosure happens when the information can be read by an unauthorized party.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Data flowing across Binary may be sniffed by an attacker. Depending on what type of data an attacker can read, it may be used to attack other parts of the system or simply be a disclosure of information leading to compliance violations. Consider encrypting the data flow.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>82ceafe9-ea4b-41f9-9200-86b17b49ffd8</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>ebdc6f14-0508-4217-80bb-a153c118b613</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>I6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D282ceafe9-ea4b-41f9-9200-86b17b49ffd823b19bb4-5a8e-4811-bd5d-1cf5b4f622acebdc6f14-0508-4217-80bb-a153c118b613</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac</b:FlowGuid><b:Id>142</b:Id><b:InteractionKey>82ceafe9-ea4b-41f9-9200-86b17b49ffd8:23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac:ebdc6f14-0508-4217-80bb-a153c118b613</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Excessive Resource Consumption for EHR Management System or Medical Imaging Storage (PACS)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Does EHR Management System or Medical Imaging Storage (PACS) take explicit steps to control resource consumption? Resource consumption attacks can be hard to deal with, and there are times that it makes sense to let the OS do the job. Be careful that your resource requests don't deadlock, and that they do timeout.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>82ceafe9-ea4b-41f9-9200-86b17b49ffd8</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>ebdc6f14-0508-4217-80bb-a153c118b613</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D482ceafe9-ea4b-41f9-9200-86b17b49ffd823b19bb4-5a8e-4811-bd5d-1cf5b4f622acebdc6f14-0508-4217-80bb-a153c118b613</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac</b:FlowGuid><b:Id>143</b:Id><b:InteractionKey>82ceafe9-ea4b-41f9-9200-86b17b49ffd8:23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac:ebdc6f14-0508-4217-80bb-a153c118b613</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Flow Binary Is Potentially Interrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent interrupts data flowing across a trust boundary in either direction.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>82ceafe9-ea4b-41f9-9200-86b17b49ffd8</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>ebdc6f14-0508-4217-80bb-a153c118b613</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D4</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D582ceafe9-ea4b-41f9-9200-86b17b49ffd823b19bb4-5a8e-4811-bd5d-1cf5b4f622acebdc6f14-0508-4217-80bb-a153c118b613</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac</b:FlowGuid><b:Id>144</b:Id><b:InteractionKey>82ceafe9-ea4b-41f9-9200-86b17b49ffd8:23b19bb4-5a8e-4811-bd5d-1cf5b4f622ac:ebdc6f14-0508-4217-80bb-a153c118b613</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Store Inaccessible</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent prevents access to a data store on the other side of the trust boundary.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>82ceafe9-ea4b-41f9-9200-86b17b49ffd8</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>ebdc6f14-0508-4217-80bb-a153c118b613</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S75b26a09b-cd4c-44c3-8c53-fe6b139cc7caac09cb47-c4e7-49a6-86b6-6084e32e38150211c5cd-ecfa-4dc6-b8d6-fb8784beb2a1</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>ac09cb47-c4e7-49a6-86b6-6084e32e3815</b:FlowGuid><b:Id>145</b:Id><b:InteractionKey>5b26a09b-cd4c-44c3-8c53-fe6b139cc7ca:ac09cb47-c4e7-49a6-86b6-6084e32e3815:0211c5cd-ecfa-4dc6-b8d6-fb8784beb2a1</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing of Source Data Store EHR Database</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>EHR Database may be spoofed by an attacker and this may lead to incorrect data delivered to Backup Storage. Consider using a standard authentication mechanism to identify the source data store.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>5b26a09b-cd4c-44c3-8c53-fe6b139cc7ca</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>0211c5cd-ecfa-4dc6-b8d6-fb8784beb2a1</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S7</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S7.15b26a09b-cd4c-44c3-8c53-fe6b139cc7caac09cb47-c4e7-49a6-86b6-6084e32e38150211c5cd-ecfa-4dc6-b8d6-fb8784beb2a1</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>f375b208-e298-4f39-9775-73bec2dbb277</b:DrawingSurfaceGuid><b:FlowGuid>ac09cb47-c4e7-49a6-86b6-6084e32e3815</b:FlowGuid><b:Id>146</b:Id><b:InteractionKey>5b26a09b-cd4c-44c3-8c53-fe6b139cc7ca:ac09cb47-c4e7-49a6-86b6-6084e32e3815:0211c5cd-ecfa-4dc6-b8d6-fb8784beb2a1</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing of Destination Data Store Backup Storage</a:Value></a:KeyValueOfstrin